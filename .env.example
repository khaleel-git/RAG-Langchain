# Copy this file to .env and set your NVIDIA values
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional global model fallback
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Task-specific model selection
NVIDIA_ATS_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_COVER_MODEL=nvidia/nvidia-nemotron-nano-9b-v2

# Optional task-specific keys (fallback is NVIDIA_API_KEY)
NVIDIA_ATS_API_KEY=
NVIDIA_COVER_API_KEY=
